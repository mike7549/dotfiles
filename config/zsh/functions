win_reboot () {
	sudo efibootmgr -n 0000
	reboot
}

update_all () {
	yay -Syu --answerdiff All --answerclean All --answeredit All --devel --diffmenu=false 
	omz update
	sudo nvim -u ~/dotfiles/config/vim/init.vim -c :PlugUpgrade -c :PlugUpdate -c :q -c :q
}

create_pyvenv () {
	if [[ $# -eq 3 ]]; then
		pyenv install $3
		pyenv shell $3
	fi
	if [[ $# -ne 2 ]]; then
		echo "Usage: create_pyvenv <venv_name> <requirements_file> <optional: python version>"
		return 1
	fi
	python -m venv $HOME/.venv/$1
	source $HOME/.venv/$1/bin/activate

	python -m pip install -r $2
}

pyvenv() {
	if [[ $# -ne 1 ]]; then
    	echo "Usage: pyvenv <venv_name>"
    	return 1
  	fi
	source $HOME/.venv/$1/bin/activate
}

adb_connect() {
	adb disconnect
	adb tcpip 5555
	sleep 3
	IP=$(adb shell ip addr show wlan0 | grep 'inet' | cut -d ' ' -f6 | cut -d/ -f1 | head -n1)
	echo "Connecting to: ${IP}"
	adb connect $IP
}
