{
	"apps": [
		{
			"auto-detach": true,
			"exclude-global-prep-cmd": false,
			"exit-timeout": 5,
			"image-path": "desktop.png",
			"name": "Desktop",
			"wait-all": true
		},
		{
			"auto-detach": false,
			"cmd": "MoonDeckStream",
			"elevated": false,
			"exclude-global-prep-cmd": false,
			"exit-timeout": 5,
			"image-path": "",
			"name": "MoonDeckStream",
			"output": "",
			"wait-all": false
		},
		{
			"auto-detach": true,
			"detached": ["setsid steam steam://open/bigpicture"],
			"exclude-global-prep-cmd": false,
			"exit-timeout": 5,
			"image-path": "steam.png",
			"name": "Steam Big Picture",
			"prep-cmd": [
				{
					"do": "",
					"undo": "setsid steam steam://close/bigpicture"
				}
			],
			"wait-all": false
		}
	],
	"env": {
		"PATH": "$(PATH):$(HOME)/.local/bin"
	}
}
